# Vercel Postgres / Neon Database Connection
# Get these from your Neon dashboard at https://console.neon.tech

# Pooler connection (recommended for most applications)
POSTGRES_URL=postgresql://username:password@host/database?channel_binding=require&sslmode=require

# Non-pooling connection (use for migrations)
POSTGRES_URL_NON_POOLING=postgresql://username:password@host/database?sslmode=require

# Individual connection parameters
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_HOST=host
POSTGRES_PORT=5432
POSTGRES_DATABASE=database

# Google Gemini API (optional, for smart alias suggestions)
API_KEY=your_google_genai_api_key_here
